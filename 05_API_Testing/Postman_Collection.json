          {
            "key": "Accept",
            "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
          },
          {
            "key": "Accept-Encoding",
            "value": "gzip, deflate"
          }
        ],
        "url": {
          "raw": "https://demo.evershop.io/search?keyword=thermos",
          "protocol": "https",
          "host": [
            "demo",
            "evershop",
            "io"
          ],
          "path": [
            "search"
          ],
          "query": [
            {
              "key": "keyword",
              "value": "thermos"
            }
          ]
        },
        "description": "Search for existing product 'thermos'. Should return 2 products."
      },
      "response": []
